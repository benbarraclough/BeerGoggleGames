---
interface Props {
  type?: string;
  players?: string;
  tags?: string[];
  base?: string;
}
const {
  type,
  players,
  tags = [],
  base = '/BeerGoggleGames'
} = Astro.props;

function slug(v?: string) {
  return (v || '')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g,'-')
    .replace(/^-|-$/g,'');
}

const typeSlug = type ? slug(type) : null;
const formatSlug = players ? slug(players) : null;
const tagList = Array.isArray(tags) ? tags : [];
---
<nav class="game-meta mb-6" aria-label="Game metadata">
  <div class="flex flex-wrap items-center gap-2 meta-primary-row">
    {typeSlug && (
      <a
        href={`${base}/games/type/${typeSlug}/`}
        class="pill-link pill-type"
        aria-label={`View all ${type} games`}
      >
        <span class="pill-dot" aria-hidden="true"></span>
        <span class="pill-text">{type}</span>
      </a>
    )}
    {formatSlug && (
      <a
        href={`${base}/games/format/${formatSlug}/`}
        class="pill-link pill-format"
        aria-label={`View all ${players} format games`}
      >
        <span class="pill-dot" aria-hidden="true"></span>
        <span class="pill-text">{players}</span>
      </a>
    )}
  </div>

  {tagList.length > 0 && (
    <div class="flex flex-wrap items-center gap-2 mt-2 meta-tags-row">
      {tagList.map(tag => {
        const tg = slug(tag);
        return (
          <a
            href={`${base}/games/tags/${tg}/`}
            class="tag-pill"
            aria-label={`Tag: ${tag}`}
          >{tag}</a>
        );
      })}
      <a
        href={`${base}/games/tags/`}
        class="tag-pill"
        aria-label="Browse all tags"
      >All Tags</a>
    </div>
  )}
</nav>
