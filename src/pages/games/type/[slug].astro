---
import BaseLayout from '../../../layouts/BaseLayout.astro';

interface GameEntry {
  frontmatter: {
    title: string;
    excerpt?: string;
    type?: string;
    players?: string;
    tags?: string[];
  };
  url: string;
}

function toSlug(v: string) {
  return v
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

export async function getStaticPaths() {
  const games: GameEntry[] = await Astro.glob('../../../content/games/*.mdx');
  const types = new Set<string>();
  for (const g of games) {
    if (g.frontmatter.type) types.add(toSlug(g.frontmatter.type));
  }
  return [...types].map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const games: GameEntry[] = await Astro.glob('../../../content/games/*.mdx');
const filtered = games.filter(g => toSlug(g.frontmatter.type || '') === slug);

const humanLabel = slug.replace(/-/g, ' ');
const pageTitle = `Game Type: ${humanLabel}`;
---
<BaseLayout title={pageTitle} description={`All games of type ${humanLabel}.`}>
  <h1 class="font-display text-4xl mb-6">{pageTitle}</h1>
  {filtered.length === 0 && <p class="text-muted">No games found for this type.</p>}
  <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {filtered
      .sort((a, b) => a.frontmatter.title.localeCompare(b.frontmatter.title))
      .map(g => (
        <li class="card">
          <a href={g.url} class="hover:text-neon font-semibold">{g.frontmatter.title}</a>
          {g.frontmatter.excerpt && (
            <p class="mt-2 text-xs text-muted leading-snug">
              {g.frontmatter.excerpt}
            </p>
          )}
        </li>
      ))}
  </ul>
</BaseLayout>
