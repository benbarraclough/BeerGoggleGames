---
import Layout from '../../../layouts/BaseLayout.astro';
const { slug } = Astro.params;

function norm(v:string) {
  return v.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
}

const games = await Astro.glob('../../../content/games/*.mdx');
const filtered = games.filter(g => {
  const tags = g.frontmatter.tags || [];
  return Array.isArray(tags) && tags.some((t:string) => norm(t) === slug);
});

const humanLabel = slug.replace(/-/g,' ');
const pageTitle = `Tag: ${humanLabel}`;
---
<Layout title={pageTitle} description={`All games tagged ${humanLabel}.`}>
  <main class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="font-display text-3xl mb-6">Tag: {humanLabel}</h1>
    {filtered.length === 0 && <p class="text-muted">No games found with this tag.</p>}
    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {filtered.map(g => (
        <li class="card">
          <a href={g.url} class="hover:text-neon font-semibold">{g.frontmatter.title}</a>
          {g.frontmatter.excerpt && <p class="mt-2 text-xs text-muted leading-snug">{g.frontmatter.excerpt}</p>}
        </li>
      ))}
    </ul>
  </main>
</Layout>
