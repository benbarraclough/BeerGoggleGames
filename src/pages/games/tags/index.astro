---
import BaseLayout from '../../../layouts/BaseLayout.astro';

function norm(v:string) {
  return v.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
}

const games = await Astro.glob('../../../content/games/*.mdx');

const tagMap = new Map<string, number>();
for (const g of games) {
  const tags = Array.isArray(g.frontmatter.tags) ? g.frontmatter.tags : [];
  tags.forEach((t:string) => {
    const s = norm(t);
    tagMap.set(s, (tagMap.get(s) || 0) + 1);
  });
}
const tagEntries = [...tagMap.entries()]
  .map(([slug,count]) => ({ slug, label: slug.replace(/-/g,' '), count }))
  .sort((a,b)=> a.label.localeCompare(b.label));

const pageTitle = 'All Game Tags';
---
<BaseLayout title={pageTitle} description="Browse all game tags.">
  <h1 class="font-display text-4xl mb-6">{pageTitle}</h1>
  {tagEntries.length === 0 && <p class="text-muted">No tags available.</p>}
  <ul class="flex flex-wrap gap-2">
    {tagEntries.map(t => (
      <li>
        <a
          href={`/BeerGoggleGames/games/tags/${t.slug}/`}
          class="tag-pill inline-flex items-center gap-1"
          aria-label={`Tag: ${t.label} (${t.count} games)`}
        >
          <span>{t.label}</span>
          <span class="opacity-70">({t.count})</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
